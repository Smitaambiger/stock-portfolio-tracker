SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use SQLite for local development (easier setup)
USE_SQLITE=True
DATABASE_URL=postgresql://postgres:password@localhost:5432/stock_portfolio_db

# Redis — use dummy cache if Redis not installed
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# Stock API — free tier from Alpha Vantage
ALPHA_VANTAGE_API_KEY=demo
